  "about": {
    "title": "About Craftree",
    "subtitle": "Understanding what civilization is made of.",
    "projectTitle": "The project",
    "projectP1": "Craftree models human inventions as fabrication recipes: a graph of dependencies between technologies.",
    "projectP2": "Unlike classic timelines that focus on when things were invented, Craftree answers a different question: what does it take to make them?",
    "projectP3": "Each invention is broken down into the materials, processes, and tools required to produce it, recursively all the way down to raw materials found in nature.",
    "projectP4": "The result is an inverted pyramid: at the top, a smartphone; at the bottom, sand and ore. In between, layers upon layers of dependencies make the full depth of fabrication visible.",
    "graphTitle": "How to read the graph",
    "graphP1": "The graph is organized in horizontal layers. Raw materials sit at the bottom; the most complex products at the top.",
    "graphP2": "Vertical position reflects fabrication depth: how many transformation steps separate an invention from nature.",
    "dimensionsTitle": "Three dimensions",
    "dimensionsIntro": "In the explorer, inventions are grouped into three dimensions:",
    "dimensionMattersTitle": "Matters",
    "dimensionMattersBody": "What things are made of — materials and substances, from raw inputs to components, organized by refinement level.",
